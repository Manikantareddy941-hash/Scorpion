#!/bin/bash

# SCORPION Pre-commit Hook
# -------------------------
# Blocks commits if secrets or critical vulnerabilities are detected in staged files.

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}[SCORPION] Running pre-commit security checks...${NC}"

# 1. Check for Gitleaks (Secrets)
if command -v gitleaks &> /dev/null; then
    echo -e "${BLUE}[SCORPION] Checking for secrets...${NC}"
    gitleaks protect --staged --verbose --redact
    if [ $? -ne 0 ]; then
        echo -e "${RED}[SCORPION] ERROR: Secrets detected in staged files!${NC}"
        echo -e "${YELLOW}Please remove the secrets or use 'git commit --no-verify' if this is a false positive.${NC}"
        exit 1
    fi
else
    echo -e "${YELLOW}[SCORPION] WARNING: gitleaks not found. Skipping secret check.${NC}"
fi

# 2. Check for Semgrep (SAST)
if command -v semgrep &> /dev/null; then
    echo -e "${BLUE}[SCORPION] Running SAST analysis on staged files...${NC}"
    
    # Get list of staged files
    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(js|ts|tsx|py|go|java|cpp|cs)$')
    
    if [ -n "$STAGED_FILES" ]; then
        semgrep scan --config auto --error $STAGED_FILES
        if [ $? -ne 0 ]; then
            echo -e "${RED}[SCORPION] ERROR: Security vulnerabilities detected by Semgrep!${NC}"
            echo -e "${YELLOW}Review the findings above. You can fix them using the SCORPION IDE extension.${NC}"
            exit 1
        fi
    fi
else
    echo -e "${YELLOW}[SCORPION] WARNING: semgrep not found. Skipping SAST check.${NC}"
fi

echo -e "${GREEN}[SCORPION] Security checks passed! Proceeding with commit.${NC}"
exit 0
